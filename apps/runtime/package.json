{
  "name": "@sonar/runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@sonar/shared": "workspace:*",
    "ed2curve": "0.3.0",
    "tweetnacl": "1.0.3",
    "tweetnacl-util": "0.15.1",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "4.1.5"
  }
}
