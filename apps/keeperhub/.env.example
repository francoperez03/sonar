# M-01 (05-MANUAL-OPS.md): KeeperHub API token from app.keeperhub.com → Account Settings → API Keys.
KEEPERHUB_API_TOKEN=

# Default https://app.keeperhub.com. Override only if KeeperHub publishes a regional/staging URL.
KEEPERHUB_BASE_URL=https://app.keeperhub.com

# M-06: Set after first successful `pnpm --filter @sonar/keeperhub publish:workflow`. The script prints
#       a JSON line { "msg": "workflow_published", "workflowId": "<id>" }; copy <id> here.
KEEPERHUB_WORKFLOW_ID=

# Phase 3 Operator default port. Phase 7 demo runs against http://localhost:8787.
OPERATOR_BASE_URL=http://localhost:8787

# REQUIRED — no default fallback (per CONTEXT D-18). MUST match the Operator's KEEPERHUB_WEBHOOK_SECRET
# (Plan 03) AND the workflow.json webhook nodes' Authorization header value. Boot fails loudly if unset.
# For local dev: set to `dev-secret` explicitly. In Phase 7 recorded run: a random 32-byte secret.
KEEPERHUB_WEBHOOK_SECRET=

# KeeperHub run-status poll interval (default 3000ms; per RESEARCH.md within KeeperHub's poll-rate ceiling).
POLL_INTERVAL_MS=3000
