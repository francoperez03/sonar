# ── Phase 4 (Operator HTTP/WS) ─────────────────────────────
# Operator HTTP plane (list_runtimes, revoke pre-check + POST /revoke).
OPERATOR_HTTP_URL=http://localhost:8787

# Operator log broadcast WS (get_workflow_log via in-memory RingBuffer).
OPERATOR_LOGS_WS=ws://localhost:8787/logs

# RingBuffer size (default 500).
LOG_BUFFER_SIZE=500

# ── Phase 5 additions (run_rotation tool) ──────────────────
# M-01 (05-MANUAL-OPS.md): KeeperHub API token (same value as apps/keeperhub/.env).
# Required to invoke run_rotation. Empty boots the server without run_rotation enabled —
# the tool itself returns mcpError('keeperhub_not_configured', ...) at invocation time.
KEEPERHUB_API_TOKEN=

# Default https://app.keeperhub.com. Override only if KeeperHub publishes a regional/staging URL.
KEEPERHUB_BASE_URL=https://app.keeperhub.com

# M-06: Captured from `pnpm --filter @sonar/keeperhub publish:workflow` output.
KEEPERHUB_WORKFLOW_ID=

# apps/keeperhub poller-server URL (default http://localhost:8788).
POLLER_BASE_URL=http://localhost:8788

# REQUIRED — no default fallback (per CONTEXT D-18 / B-02). MUST match apps/operator AND
# apps/keeperhub values. Boot fails loudly if unset. For local dev: set to `dev-secret`.
KEEPERHUB_WEBHOOK_SECRET=
