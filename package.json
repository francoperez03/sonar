{
  "name": "sonar",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm -F @sonar/landing dev",
    "preview": "pnpm -F @sonar/landing preview",
    "test": "pnpm -F @sonar/landing test",
    "test:e2e": "pnpm -F @sonar/landing test:e2e",
    "lhci": "pnpm -F @sonar/landing lhci",
    "lint": "pnpm -F @sonar/landing lint",
    "dev:operator": "pnpm --filter @sonar/operator dev",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.21.0",
    "prettier": "^3.8.0",
    "@types/node": "^20.11.0"
  },
  "engines": {
    "node": ">=20"
  }
}
