{
  "name": "sonar",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:operator": "pnpm --filter @sonar/operator dev",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.21.0",
    "prettier": "^3.8.0",
    "@types/node": "^20.11.0"
  },
  "engines": {
    "node": ">=20"
  }
}
